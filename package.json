{
  "name": "virelio",
  "version": "0.1.0",
  "description": "Invoice and Expense Tracker",
  "author": "Aymane Bouljam",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm -r build",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "seed": "pnpm --filter backend seed",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter backend test:e2e",
    "typecheck": "pnpm -r typecheck",
    "prisma:format": "pnpm --filter backend exec prisma format",
    "prisma:generate": "pnpm --filter backend exec prisma generate",
    "prisma:validate": "pnpm --filter backend exec prisma validate",
    "prisma:migrate:dev": "pnpm --filter backend exec prisma migrate dev",
    "prisma:migrate:deploy": "pnpm --filter backend exec prisma migrate deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.22.4"
  },
  "lint-staged": {
    "frontend/**/*.{ts,js,css,json,md,vue}": [
      "pnpm --filter frontend exec oxfmt"
    ],
    "frontend/**/*.{ts,js}": [
      "pnpm --filter frontend exec oxlint --fix"
    ],
    "frontend/**/*.vue": [
      "pnpm --filter frontend exec eslint --fix"
    ],
    "backend/**/*.{ts,js}": [
      "pnpm --filter backend exec prettier --write",
      "pnpm --filter backend exec eslint --fix"
    ],
    "backend/**/*.{json,md}": [
      "pnpm --filter backend exec prettier --write"
    ]
  }
}
